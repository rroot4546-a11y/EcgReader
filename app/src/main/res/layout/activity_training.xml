<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 Training Data"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload ECG images with known diagnoses to improve AI accuracy"
            android:textSize="14sp"
            android:textColor="#666666"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/tvTrainingCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 Training data: 0 ECG records"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/btnPickTraining"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="📷 Upload ECG Image"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp" />

                <ImageView
                    android:id="@+id/ivTrainingPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="Preview" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Diagnosis (e.g., Atrial Fibrillation, STEMI)"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTrainingDiagnosis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Symptoms (optional)"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTrainingSymptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnAddTraining"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="➕ Add Training Data"
                    android:textAllCaps="false"
                    app:backgroundTint="#D32F2F" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTrainingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center" />
    </LinearLayout>
</ScrollView>
